#!/usr/bin/env sh
set -eu
. "$(dirname "$0")/_common.sh"
"$(dirname "$0")/godot-smoke"
GODOT_BIN=${GODOT_BIN:?Set GODOT_BIN to the Godot 4.7 stable .NET executable.}
EXPORT_ROOT="$ROOT/build/exports/windows"
MANAGED_ROOT="$EXPORT_ROOT/data_Igorogue.Godot_windows_x86_64"
rm -rf "$EXPORT_ROOT"
mkdir -p "$EXPORT_ROOT"
"$GODOT_BIN" --headless --path game/Igorogue.Godot --export-debug "Windows Debug" "$EXPORT_ROOT/Igorogue.exe"
git diff --quiet -- ':(glob)**/packages.lock.json' || {
  echo "Godot export modified committed NuGet lock files." >&2
  exit 1
}
test -f "$EXPORT_ROOT/Igorogue.exe"
test -d "$MANAGED_ROOT"
test -f "$MANAGED_ROOT/Igorogue.Godot.dll"
"$PYTHON_BIN" tools/hash_artifact.py "$EXPORT_ROOT/Igorogue.exe"
