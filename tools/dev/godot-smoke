#!/usr/bin/env sh
set -eu
. "$(dirname "$0")/_common.sh"
"$PYTHON_BIN" tools/verify_toolchain.py
"$PYTHON_BIN" tools/content_sync.py --check
GODOT_BIN=${GODOT_BIN:?Set GODOT_BIN to the Godot 4.7 stable .NET executable.}
export GODOT_BIN
"$GODOT_BIN" --headless --path game/Igorogue.Godot --editor --build-solutions --quit
"$GODOT_BIN" --headless --path game/Igorogue.Godot --quit-after 120
